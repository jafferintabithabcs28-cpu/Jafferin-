#include<iostream>
using namespace std;
int main()
{
   int n,i,j,v;
   cout<<"Enter the size of array"<<endl;
   cin>>n;
   int a[n];
   cout<<"Enter the array elements"<<endl;
   for(i=0;i<n;i++)
   {
      cin>>a[i];
   }
   for(i=1;i<=n-1;i++)
   {
      v=a[i];
      j=i-1;
      while(j>=0 && a[j]>v)
      {
         a[j+1]=a[j];
         j=j-1;
      }
      a[j+1]=v;
   }
   cout<<"After insertion sort"<<endl;
   for(i=0;i<n;i++)
   {
      cout<<a[i]<<"\t";
   }
   cout<<endl;
}
