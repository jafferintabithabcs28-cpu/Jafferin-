#include<iostream>
using namespace std;
int hoareParition(int a[],int low,int high)
{
   int pivot=a[low];
   int i=low-1;
   int j=high+1;
   while(true)
   {
      do
      {
         i++;
      }while (a[i]<pivot);
      do
      {
         j--;
      }while(a[j]>pivot);
      if(i>=j)
      {
         return j;
      }
      swap(a[i],a[j]);
   }
}
void quick_sort(int a[],int low,int high)
{
   if(low<high)
   {
      int p=hoareParition(a,low,high);
      quick_sort(a,low,p);
      quick_sort(a,p+1,high);
   }
}
int main()
{
   int n;
   cout<<"Enter the array size"<<endl;
   cin>>n;
   int a[n];
   cout<<"Enter the array elements"<<endl;
   for(int i=0;i<n;i++)
   {
      cin>>a[i];
   }
   quick_sort(a,0,n-1);
   cout<<"Sorted array"<<endl;
   for(int i=0;i<n;i++)
   {
      cout<<a[i]<<" ";
   }
   return 0;
}

