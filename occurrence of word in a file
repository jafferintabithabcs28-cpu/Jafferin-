with open("file.txt","r") as f:
   text=f.read().lower()
punctions="!.,?':;"
for char in punctions:
   text=text.replace(char,"")
w=text.split()
word={}
for i in w:
   if i in word:
      word[i]+=1
   else:
      word[i]=1
for i,j in word.items():
   print(i,":",j)
