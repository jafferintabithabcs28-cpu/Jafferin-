void merge(int *a,int l,int m,int n)
{
   int i=l,j=m+1,k=l;
   int *temp=new int[n+1];
   while(i<=m && j<=n)
   {
      if(a[i]<=a[j])
      {
         temp[k++]=a[i++];
      }
      else
      {
         temp[k++]=a[j++];
      }
   }
      while(i<=m)
      {
         temp[k++]=a[i++];
      }
      while(j<=n)
      {
         temp[k++]=a[j++];
      }
      for(i=l;i<=n;i++)
      {
         a[i]=temp[i];
      }

}
void merge_sort(int *a,int l,int n)
{
   if(l<n)
   {
      int m=(l+n)/2;
      merge_sort(a,l,m);
      merge_sort(a,m+1,n);
      merge(a,l,m,n);
   }
}
