#include<iostream>
using namespace std;
void heapify(int *a,int n);
void heapsort(int *a,int n);
int main()
{
   int n,k,v,i,j;
   bool heap;
   cout<<"Enter the size of array"<<endl;
   cin>>n;
   int *a;
   a=new int[n+1];
   cout<<"Enter the array elements"<<endl;
   for(i=1;i<=n;i++)
   {
      cin>>a[i];
      //cout<<"\n";
   }
   heapsort(a,n);
   cout<<"Sorted Bottom up heap construction"<<endl;
   for(int i=1;i<=n;i++)
   {
      cout<<a[i]<<"\t";
   }
   cout<<endl;
}
void heapify(int *a,int n)
{
   int i,v,k,j;
   for(int i=n/2;i>0;i--)
   {
      k=i;
      v=a[k];
      bool heap=false;
      while(!heap && 2*k<=n)
      {
         j=2*k;
         if (j<n)
         {
            if (a[j]<a[j+1])
            {
               j=j+1;
            }
         }
         if (v>=a[j])
         {
            heap=true;
         }
         else
         {
            a[k]=a[j];
            k=j;
         }
      }
      a[k]=v;
   }
}
void heapsort(int *a,int n)
{
   heapify(a,n);
   cout<<"The array after max heap"<<endl;
   for(int i=1;i<=n;i++)
   {
      cout<<a[i]<<"\t";
   }
   cout<<"\n";
   for(int i=n;i>1;i--)
   {
      int temp=a[1];
      a[1]=a[i];
      a[i]=temp;
      heapify(a,i-1);
   }
}
