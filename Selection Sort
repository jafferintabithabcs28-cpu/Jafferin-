#include<iostream>
using namespace std;
int main()
{
   int *a,i,j,min,n;
   cout<<"Enter the size of the array"<<endl;
   cin>>n;
   a=new int[n];
   cout<<"Enter the array elements"<<endl;
   for(int i=0;i<n;i++)
   {
      cin>>a[i];
   }
   cout<<"The array before sorted"<<endl;
   for(i=0;i<n;i++)
   {
      cout<<a[i]<<"\t";
   }
   cout<<endl;
   for(int i=0;i<n-1;i++)
   {
      min=i;
      for(int j=i+1;j<n;j++)
      {
         if(a[j]<a[min])
         {
            min=j;
         }
      }
      if(min!=i)
      {
         int temp=a[i];
         a[i]=a[min];
         a[min]=temp;
      }
   }
   cout<<"The sorted array is"<<endl;
   for(int i=0;i<n;i++)
   {
      cout<<a[i]<<"\t";
   }
   cout<<endl;
}
