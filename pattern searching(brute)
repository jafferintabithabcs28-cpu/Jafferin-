#include<iostream>
using namespace std;
int main()
{
   int i,j,n,m;
   char t[100],p[100];
   cout<<"Enter the text string"<<endl;
   cin.getline(t,100);
   cout<<"\n";
   j=0;
   n=0;
   m=0;
   cout<<"Enter the pattern string"<<endl;
   cin.getline(p,100);
   while(t[n]!='\0')
   {
      n++;
   }
   cout<<"The length of text"<<n<<endl;
   while(p[m]!='\0')
   {
      m++;
   }
   cout<<"The length of pattern"<<m<<endl;
   for(int i=0;i<n;i++)
   {
      int j=0;
      while(j<m && p[j]==t[i+j])
      {
         cout<<t<<endl;
         for (int l=0;l<=j;l++)
         {
            cout<<p[l]<<endl;
            cout<<" "<<endl;
         }
         //cout<<p<<endl;
         j=j+1;
      }
      if(j==m)
      {
         cout<<"Pattern is found in text"<<i<<endl;
         //cout<<i;
         return 0;

      }
   }
   //if(j!=m)
   //{
   cout<<"Patter not found in text"<<endl;
   return 0;
  // }
}
