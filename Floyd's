#include<iostream>
using namespace std;
int main()
{
   int n;
   cout<<"Enter the size of the matrix"<<endl;
   cin>>n;
   int d[n][n];
   cout<<"Enter the matrix"<<endl;
   for(int i=0;i<n;i++)
   {
      for(int j=0;j<n;j++)
      {
         cin>>d[i][j];
      }
   }
   for(int k=0;k<n;k++)
   {
      for(int i=0;i<n;i++)
      {
         for(int j=0;j<n;j++)
         {
            d[i][j]=min(d[i][j],(d[i][k]+d[k][j]));
         }
      }
   }
   for(int i=0;i<n;i++)
   {
      if(d[i][i]<0)
      {
         cout<<"Negative cycle detected\n";
         return 0;
      }
   }
   cout<<"Shortest path matrix\n";
   for(int i=0;i<n;i++)
   {
      for(int j=0;j<n;j++)
      {
         cout<<d[i][j]<<" ";
      }
      cout<<endl;
   }
   return 0;
}
